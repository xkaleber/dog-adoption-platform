<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dog Adoption Platform</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <nav>
    <h1><a href="/">Dog Adoption Platform</a></h1>
    <ul>
      <% if (user) { %>
        <li>Welcome, <%= user.username %></li>
        <li><a href="#" onclick="logoutUser(event)">logout</a></li>
      <% } else { %>
        <li><a href="/login">login</a></li>
        <li><a href="/signup" class="btn">sign up</a></li>
      <% } %>
    </ul>
  </nav>

  <script>
  async function logoutUser(e) {
    e.preventDefault(); // Stop the link from redirecting
    
    const res = await fetch('/logout', { method: 'POST' });
    const data = await res.json();
    
    if (data.logout) {
      window.location.assign('/'); // Safe client-side redirect back home
    }
  }
</script>