<%- include('partials/header'); -%>

<form>
    <h2>log in</h2>
    <label for="username">username:</label>
    <input type="text" name="username" required />
    <div class="username error"></div>
    <label for="password">password:</label>
    <input type="password" name="password" required />
    <div class="password error"></div>
    <button type="submit">Log in</button>
</form>

<script>
  const form = document.querySelector('form');
  const usernameError = document.querySelector('.username.error');
  const passwordError = document.querySelector('.password.error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Reset error messages from previous attempts
    usernameError.textContent = '';
    passwordError.textContent = '';

    // Capture user input safely
    const username = form.username.value.trim(); // Trim spaces to prevent accidental typos
    const password = form.password.value;

    try {
      const res = await fetch('/login', {
        method: 'POST',
        body: JSON.stringify({ username, password }),
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include' // Enforces storing the HttpOnly cookie securely
      });

      // Safely extract JSON data regardless of status code
      const data = await res.json();
      console.log(data);

      // Handle validation/login errors returned by the controller
      if (data.errors) {
        usernameError.textContent = data.errors.username || '';
        passwordError.textContent = data.errors.password || '';
        return; // Halt execution
      }

      // If the login is successful and the user ID is returned
      if (res.ok && data.user) {
        location.assign('/'); // Redirect safely to home page
      }
      
    } catch (err) {
      console.error('Network or parsing error occurred:', err);
      // Fallback UI indication for complete connection loss
      usernameError.textContent = 'Unable to connect to the server. Please try again.';
    }
  });
</script>

<%- include('partials/footer'); -%>